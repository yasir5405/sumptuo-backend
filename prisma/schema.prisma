// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                Int                  @id @default(autoincrement())
  email             String               @unique
  passwordHash      String
  name              String
  googleId          String?              @unique
  profileImage      String?
  currency          String               @default("INR")
  isPro             Boolean              @default(false)
  proExpiresAt      DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  refreshTokens     RefreshToken[]
  resetTokens       ResetPasswordToken[]
  connectedAccounts ConnectedAccount[]
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ResetPasswordToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model ConnectedAccount {
  id            Int             @id @default(autoincrement())
  userId        Int
  platform      Platform
  accessToken   String
  expiresAt     DateTime
  adAccountId   String
  adAccountName String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  insights      CachedInsight[]

  @@unique([userId, platform, adAccountId])
}

model CachedInsight {
  id                 Int      @id @default(autoincrement())
  connectedAccountId Int
  date               DateTime @db.Date
  campaignId         String
  campaignName       String
  status             String
  spend              Decimal  @db.Decimal(12, 2)
  impressions        Int
  clicks             Int
  ctr                Decimal  @db.Decimal(6, 4)
  cpm                Decimal  @db.Decimal(10, 2)
  conversions        Int      @default(0)
  revenue            Decimal  @default(0) @db.Decimal(12, 2)
  fetchedAt          DateTime @default(now())

  connectedAccount ConnectedAccount @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)

  @@unique([connectedAccountId, campaignId, date])
  @@index([connectedAccountId, date])
}

enum Platform {
  META
}
